---
import { brands, getCategory, type Product } from '../data/products';
import { withBase } from '../lib/base';

interface Props {
  product: Product;
}
const { product } = Astro.props;
const brand = brands[product.brand];
const category = getCategory(product.category);
const tint = category?.tint ?? ['#f4e7e0', '#e6c9cf'];
const askHref = withBase(`/contact?product=${encodeURIComponent(product.name)}#inquiry`);
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-blush-deep/50 bg-ivory shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg">
  <!-- Image / fallback tile -->
  <div class="relative aspect-[4/3] overflow-hidden">
    {product.image ? (
      <img
        src={withBase(product.image)}
        alt={product.name}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div
        class="flex h-full w-full items-center justify-center"
        style={`background-image: linear-gradient(140deg, ${tint[0]}, ${tint[1]});`}
        aria-hidden="true"
      >
        <span class="font-display text-4xl text-plum/25">{brand.name}</span>
      </div>
    )}
    <span class="absolute left-3 top-3 rounded-full bg-ivory/90 px-3 py-1 text-xs font-semibold text-brand-deep shadow-sm backdrop-blur">
      {brand.name}
    </span>
  </div>

  <!-- Body -->
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-lg leading-snug text-plum">{product.name}</h3>
    <p class="mt-2 text-sm text-plum-soft">{product.blurb}</p>

    {product.features && product.features.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {product.features.slice(0, 3).map((f) => (
          <li class="rounded-full bg-blush px-2.5 py-1 text-xs text-plum-soft">{f}</li>
        ))}
      </ul>
    )}

    <div class="mt-5 flex items-center gap-3 pt-1">
      <a
        href={askHref}
        class="inline-flex flex-1 items-center justify-center rounded-full bg-brand px-4 py-2 text-sm font-semibold text-ivory no-underline transition-colors hover:bg-brand-deep"
      >
        Ask Jen about this
      </a>
      <a
        href={product.supplierUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1 rounded-full px-3 py-2 text-sm font-semibold text-brand-deep no-underline ring-1 ring-brand/30 transition-colors hover:bg-blush"
        aria-label={`View ${product.name} details on the ${brand.name} website (opens in a new tab)`}
      >
        Details
        <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M5 3h8v8M13 3L4 12" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</article>
