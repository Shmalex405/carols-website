---
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { contact, social } from '../config';
import { withBase } from '../lib/base';

const mapEmbed = `https://maps.google.com/maps?q=${encodeURIComponent(
  `${contact.address.line1} ${contact.address.city} ${contact.address.state} ${contact.address.zip}`,
)}&output=embed`;
---

<BaseLayout
  title="Contact & Ask Jen"
  description="Reach Carol's Post Mastectomy Specialist in St. George, Utah. Call, email, or send Jen a friendly note — by appointment, Monday through Thursday."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-blush to-cream"></div>
    <div class="mx-auto max-w-4xl px-6 py-16 text-center lg:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sage-deep">Contact</p>
      <h1 class="mt-3 text-4xl sm:text-5xl">We’d love to hear from you</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-plum-soft">
        Have a question, or something here caught your eye? Send Jen a note and she’ll personally get
        back to you. There’s no obligation — just caring, honest help.
      </p>
    </div>
  </section>

  <!-- Our welcoming space -->
  <section class="mx-auto max-w-5xl px-6 pb-4">
    <figure class="overflow-hidden rounded-[2rem] shadow-lg ring-1 ring-ivory/60">
      <img
        src={withBase('/images/fitting-room.webp')}
        width="1400"
        height="933"
        loading="lazy"
        alt="Carol's private fitting room — pink armchairs, a sunny window, and a wall of pink-ribbon keepsakes"
        class="w-full object-cover"
      />
      <figcaption class="bg-ivory px-6 py-4 text-center text-sm text-plum-soft">
        Come as you are into a calm, private space — never a busy sales floor.
      </figcaption>
    </figure>
  </section>

  <section class="mx-auto grid max-w-6xl gap-10 px-6 py-12 lg:grid-cols-[1fr_1.3fr]">
    <!-- Contact details -->
    <div>
      <div class="rounded-[1.75rem] border border-blush-deep/60 bg-ivory p-7 shadow-sm">
        <h2 class="text-2xl text-plum">Visit or call</h2>

        <div class="mt-5 space-y-5 text-plum-soft">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-brand-deep">Address</h3>
            <address class="mt-1 not-italic">
              {contact.address.line1}<br />
              {contact.address.line2}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </address>
            <a href={contact.mapsUrl} target="_blank" rel="noopener" class="mt-1 inline-block text-sm font-semibold text-brand-deep">Get directions →</a>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-brand-deep">Phone</h3>
            <p class="mt-1"><a href={contact.phoneHref} class="text-plum no-underline hover:text-brand-deep">{contact.phone}</a></p>
            <p class="text-sm text-plum-mute">Fax {contact.fax}</p>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-brand-deep">Email</h3>
            <p class="mt-1"><a href={contact.emailHref} class="text-plum no-underline hover:text-brand-deep">{contact.email}</a></p>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-brand-deep">Hours</h3>
            <dl class="mt-1 space-y-0.5">
              {contact.hours.map((h) => (
                <div class="flex justify-between gap-6">
                  <dt>{h.days}</dt>
                  <dd>{h.time}</dd>
                </div>
              ))}
            </dl>
            <p class="mt-2 text-sm text-plum-mute">{contact.hoursNote}</p>
          </div>

          <div class="flex gap-4 pt-1 text-sm">
            <a href={social.instagram} target="_blank" rel="noopener" class="font-semibold text-brand-deep no-underline">Instagram</a>
            <a href={social.facebook} target="_blank" rel="noopener" class="font-semibold text-brand-deep no-underline">Facebook</a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="mt-6 overflow-hidden rounded-[1.75rem] border border-blush-deep/60 shadow-sm">
        <iframe
          title="Map to Carol's Post Mastectomy Specialist"
          src={mapEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="h-64 w-full border-0"
        ></iframe>
      </div>

      <!-- Find the building -->
      <figure class="mt-6 overflow-hidden rounded-[1.75rem] border border-blush-deep/60 shadow-sm">
        <img
          src={withBase('/images/building.webp')}
          width="900"
          height="1602"
          loading="lazy"
          alt="Coral Desert Health Center in St. George, Utah — the building Carol's is located in"
          class="aspect-[4/5] w-full object-cover object-top"
        />
        <figcaption class="bg-ivory px-5 py-3 text-sm text-plum-soft">
          Look for <span class="font-semibold text-plum">Coral Desert Health Center</span> — we’re in Suite 310, third floor.
        </figcaption>
      </figure>
    </div>

    <!-- Inquiry form -->
    <div>
      <h2 class="text-2xl text-plum">Send Jen a note</h2>
      <p class="mt-2 text-plum-soft">Tell us a little about what you’re looking for.</p>
      <div class="mt-5">
        <InquiryForm />
      </div>
    </div>
  </section>
</BaseLayout>
