---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { people, contact } from '../config';
import { categories } from '../data/products';

const pillars = [
  {
    title: 'Personal & private',
    body: 'Unhurried, one-on-one fittings in a calm, private room — never a checkout line. Just you and Jen, for as long as you need.',
  },
  {
    title: 'Truly expert',
    body: `${people.fitterName} is a Certified Mastectomy Fitter with 20+ years of experience, also certified in fitting lymphedema compression.`,
  },
  {
    title: 'Insurance help',
    body: 'Breast forms and post-mastectomy bras are often covered by private insurance. We help you understand your benefits and handle the paperwork.',
  },
];

const steps = [
  {
    n: '01',
    title: 'Browse with ease',
    body: 'Explore breast forms, bras, camisoles, swimwear, and compression from the brands we carry — no prices to compare, no pressure.',
  },
  {
    n: '02',
    title: 'Tell Jen what caught your eye',
    body: 'Send a friendly note through the site or book straight into Jen’s calendar. No cart, no checkout — just a real conversation.',
  },
  {
    n: '03',
    title: 'Come in for your fitting',
    body: 'Jen fits everything in person so it feels right and looks beautiful — and orders exactly what suits you best.',
  },
];
---

<BaseLayout>
  <!-- ───────────────────────── Hero ───────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-blush via-cream to-sage-soft/40"></div>
    <div class="absolute -right-24 -top-24 -z-10 h-96 w-96 rounded-full bg-brand-soft/25 blur-3xl"></div>
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 lg:grid-cols-2 lg:py-28">
      <div>
        <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-ivory/70 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-brand-deep ring-1 ring-brand/20">
          St. George, Utah · Since 1985
        </p>
        <h1 class="text-4xl leading-[1.08] sm:text-5xl lg:text-6xl">
          Care that feels like being<br class="hidden sm:block" />
          <span class="italic text-brand-deep">welcomed home.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg text-plum-soft">
          Compassionate, private, one-on-one mastectomy fittings — breast forms, bras, camisoles,
          swimwear, and lymphedema compression — from a specialist who understands.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/book" size="lg">Book an Appointment</Button>
          <Button href="/products" variant="ghost" size="lg">Explore Products</Button>
        </div>
        <p class="mt-6 text-sm text-plum-soft">
          Prefer to talk? Call
          <a href={contact.phoneHref} class="font-semibold text-brand-deep">{contact.phone}</a> —
          by appointment, Mon–Thu.
        </p>
      </div>

      <!-- Jen — the fitter you'll meet -->
      <div class="relative">
        <div class="aspect-[4/5] w-full overflow-hidden rounded-[2rem] shadow-xl shadow-brand/10 ring-1 ring-ivory/60">
          <img
            src="/images/jen.webp"
            width="1100"
            height="1143"
            alt="Jen Flowers, Certified Mastectomy Fitter at Carol's, smiling warmly"
            fetchpriority="high"
            class="h-full w-full object-cover object-center"
          />
        </div>
        <div class="absolute bottom-5 left-5 right-5 rounded-2xl bg-ivory/85 p-5 backdrop-blur">
          <p class="font-display text-xl text-plum">{people.fitterName}</p>
          <p class="mt-1 text-sm text-plum-soft">
            {people.fitterTitle} · carrying on her mother {people.founderName}’s legacy
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────── Reassurance pillars ───────────────────── -->
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-3">
      {pillars.map((p) => (
        <div class="rounded-2xl border border-blush-deep/50 bg-ivory p-7 shadow-sm">
          <h3 class="text-xl text-brand-deep">{p.title}</h3>
          <p class="mt-3 text-plum-soft">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ───────────────────────── Products ───────────────────────── -->
  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="mb-10 max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage-deep">What we carry</p>
      <h2 class="mt-2 text-3xl sm:text-4xl">Everything for comfort, confidence, and you</h2>
      <p class="mt-4 text-plum-soft">
        We bring together the most trusted names — Amoena, American Breast Care, Trulife, Nearly Me,
        Almost U, and Juzo — so you can find what feels right, then have it fitted in person.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <a
          href={`/products/${cat.slug}`}
          class="group relative flex min-h-52 flex-col justify-end overflow-hidden rounded-2xl p-6 no-underline shadow-sm ring-1 ring-blush-deep/50 transition-all hover:-translate-y-1 hover:shadow-lg"
          style={`background-image: linear-gradient(140deg, ${cat.tint[0]}, ${cat.tint[1]});`}
        >
          <h3 class="text-2xl text-plum">{cat.title}</h3>
          <p class="mt-1 text-sm text-plum-soft">{cat.short}</p>
          <span class="mt-3 text-sm font-semibold text-brand-deep">
            Explore <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ───────────────────────── How it works ───────────────────────── -->
  <section class="mt-8 bg-plum/[0.03]">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="mb-10 max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage-deep">How it works</p>
        <h2 class="mt-2 text-3xl sm:text-4xl">A gentle, personal process</h2>
        <p class="mt-4 text-plum-soft">
          We’re a fitting specialist, not an online store. You find what you love here — the fitting
          and ordering happen with Jen, in person.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {steps.map((s) => (
          <div class="rounded-2xl bg-ivory p-7 shadow-sm ring-1 ring-blush-deep/50">
            <span class="font-display text-3xl text-brand-soft">{s.n}</span>
            <h3 class="mt-2 text-xl text-plum">{s.title}</h3>
            <p class="mt-2 text-plum-soft">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Story teaser ───────────────────────── -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Carol & Jen together -->
      <div class="order-2 aspect-[5/4] overflow-hidden rounded-[2rem] shadow-lg ring-1 ring-ivory/60 lg:order-1">
        <img
          src="/images/carol-and-jen.webp"
          width="1100"
          height="1086"
          loading="lazy"
          alt="Carol Stenquist and her daughter Jen Flowers together, smiling"
          class="h-full w-full object-cover object-top"
        />
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage-deep">Our story</p>
        <h2 class="mt-2 text-3xl sm:text-4xl">A daughter’s promise, a mother’s love</h2>
        <p class="mt-4 text-plum-soft">
          Carol Stenquist opened Carol’s in 1985 to give women a place of comfort during the hardest
          days. Her daughter Jen grew up in that circle of care, became a Certified Mastectomy Fitter,
          and — after losing Carol in 2011 — carries the legacy forward every single day.
        </p>
        <div class="mt-6">
          <Button href="/our-story" variant="ghost">Read our story</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Final CTA ───────────────────────── -->
  <section class="mx-auto max-w-5xl px-6 pb-8">
    <div class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-brand to-brand-deep px-8 py-14 text-center shadow-xl">
      <h2 class="text-3xl text-ivory sm:text-4xl">Let’s find what feels right for you</h2>
      <p class="mx-auto mt-4 max-w-xl text-blush">
        Book a private appointment with Jen, or send a note about anything you saw here. There’s no
        pressure — only care.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/book" variant="secondary" size="lg">Book an Appointment</Button>
        <Button href="/contact" variant="ghost" size="lg" class="!text-ivory !ring-ivory/50 hover:!bg-ivory/10">Ask a Question</Button>
      </div>
    </div>
  </section>
</BaseLayout>
